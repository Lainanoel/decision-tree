        else { test_name <- "Negative Binomial regression"; desc <- "Negative binomial regression is a generalized linear model used to model count data when the variance is significantly larger than the mean, known as overdispersion. By adding a specific dispersion parameter to the model framework, it relaxes the rigid 'variance equals mean' assumption of standard Poisson regression to provide accurate standard errors and prevent overconfident conclusions."; use <- "Use for count predictions when variance exceeds mean."; assump <- "Negative binomial distribution."; next_steps <- "Evaluate the dispersion parameter. Use cross-validation or hold-out data to assess the accuracy of the count predictions."; dive_topic <- "Overdispersion" }
