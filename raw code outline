#define server
server <- function(input, output, session) {
  observeEvent(input$reset, { updateSelectInput(session, "goal", selected = "") })
  observeEvent(input$go_to_deepdive, { updateNavbarPage(session, "nav", selected = "deepdive") })
  #use reactive
  get_rec <- reactive({
    req(input$goal)
    goal_val <- input$goal
    res_type <- if (isTruthy(input$response_type)) input$response_type else ""
    test_name <- NULL; desc <- NULL; use <- NULL; assump <- NULL; next_steps <- NULL; dive_topic <- NULL
    #logic tree
    #compare the groups
    if (identical(goal_val, "Compare groups")) {
      if (identical(res_type, "Continuous")) {
        str_val <- if (isTruthy(input$structure)) input$structure else ""
        if (identical(str_val, "Completely Randomized Design (CRD)")) {
          det_val <- if (isTruthy(input$num_groups)) input$num_groups else ""
          ass_val <- if (isTruthy(input$assumptions)) input$assumptions else ""
          if (identical(det_val, "2 groups") && ass_val != "") {
            if (identical(ass_val, "Yes")) { test_name <- "Independent t-test"; desc <- "Compares the means of two independent groups."; use <- "An independent $t$-test is a statistical method used to compare the means of two separate, unrelated groups to determine if there is a significant difference between them. For example, it can evaluate whether a treatment group performed better on a test than a control group that received no treatment."; assump <- "Normality, homogeneity of variance, independence of observations."; next_steps <- "Perform a Shapiro-Wilk test for normality and Levene's test for equality of variances. If significant, report the t-statistic, degrees of freedom, and p-value."; dive_topic <- "Homoscedasticity" }
            else { test_name <- "MannŌĆōWhitney U test"; desc <- "The Mann-Whitney U test is a non-parametric statistical method used to compare the distributions of two independent groups when the data do not meet the normality assumptions required for a standard t-test. Instead of comparing averages, it ranks all the data points to determine if one group's values systematically tend to be larger or smaller than the other's."; use <- "Use when assumptions for the t-test are not met or data are ordinal."; assump <- "Independence of observations, ordinal or continuous data."; next_steps <- "Rank the data points across groups and perform the test. Report the U-statistic and p-value, and consider the median difference if distributions are similar." }
          } else if (identical(det_val, ">2 groups") && ass_val != "") {
            if (identical(ass_val, "Yes")) { test_name <- "One-way ANOVA"; desc <- "A one-way ANOVA (Analysis of Variance) test is a statistical method used to compare the means of three or more independent groups with continuous data to see if at least one group differs significantly from the others. For example, it can evaluate whether there is a difference in exam scores among students who used three distinct studying techniques."; use <- "A one-way ANOVA (Analysis of Variance) test is a statistical method used to compare the means of three or more independent groups with continuous data to see if at least one group differs significantly from the others."; assump <- "Normality, homogeneity of variance, independence of observations."; next_steps <- "Perform the ANOVA. If the result is significant (p < 0.05), follow up with a Tukey's HSD post-hoc test to identify which specific groups differ."; dive_topic <- "Homoscedasticity" }
            else { test_name <- "KruskalŌĆōWallis test"; desc <- "Non-parametric alternative to one-way ANOVA."; use <- "The Kruskal-Wallis test is a non-parametric statistical method used to compare the distributions of three or more independent groups when the data do not meet the normality assumptions required for a one-way ANOVA. Instead of comparing group means, it ranks all data points combined to determine if at least one group's scores systematically differ from the others."; assump <- "Independence of observations, ordinal or continuous data."; next_steps <- "Perform the test on the ranks of the data. If significant, use a post-hoc test like Dunn's test to perform pairwise comparisons between groups." }
          }
        } else if (identical(str_val, "RCBD") && (ass_val <- if (isTruthy(input$assumptions)) input$assumptions else "") != "") {
          if (identical(ass_val, "Yes")) { test_name <- "RCBD ANOVA"; desc <- "A Randomized Complete Block Design (RCBD) ANOVA is a statistical method used to compare the means of three or more groups while controlling for an extraneous variable, known as a block, that could skew the results. For example, it can evaluate the effectiveness of three different treatments across multiple field locations, using the locations as blocks to filter out variations in soil quality."; use <- "Use for blocked experimental designs where assumptions are met."; assump <- "Normality, homogeneity of variance."; next_steps <- "Include the 'Block' effect in your model. Check the significance of the treatment effect while accounting for block-to-block variation."; dive_topic <- "Homoscedasticity" }
          else { test_name <- "Friedman test"; desc <- "The Friedman test is a non-parametric statistical method used to detect differences in treatments across multiple test attempts or matched groups when the data do not meet the assumptions of normality. It essentially serves as the non-parametric alternative to a repeated measures ANOVA, ranking the data within each block or subject to see if there is a consistent, significant trend."; use <- "Use for blocked designs when assumptions are not met."; assump <- "Independence within blocks."; next_steps <- "Organize data into a matrix by blocks and treatments. Perform the test and use Nemenyi post-hoc tests if the overall result is significant." }
        } else if (identical(str_val, "Split-plot") && (ass_val <- if (isTruthy(input$assumptions)) input$assumptions else "") != "") {
          if (identical(ass_val, "Yes")) { test_name <- "Split-plot ANOVA"; desc <- "A split-plot ANOVA is a statistical method used when experimental units are nested within two different levels of treatment, separating them into large whole plots for one factor and smaller subplots for another. For example, it can evaluate how different irrigation types (whole-plot factor) and fertilizer brands (subplot factor) affect crop yield within the same field."; use <- "Use for split-plot designs with assumptions met."; assump <- "Normality, homogeneity of variance."; next_steps <- "Ensure you use the correct error terms (whole-plot error vs subplot error) to calculate the F-statistics for each factor level."; dive_topic <- "Homoscedasticity" }
          else { test_name <- "Mixed model with transformed/nonparametric approach"; desc <- "A mixed model with a transformed nonparametric approach applies a mathematical transformationŌĆösuch as ranking or aligned ranksŌĆöto the data before running a linear mixed-effects model to handle complex, non-normal datasets with both fixed and random effects. This hybrid method allows researchers to robustly analyze longitudinal or clustered data with repeated measures without violating standard parametric assumptions like normality and homoscedasticity."; use <- "Use when assumptions are violated; may require data transformation."; assump <- "More flexible than ANOVA."; next_steps <- "Consider using a rank-transformation or an Aligned Rank Transform (ART) before fitting your mixed-effects model." }
        } else if (identical(str_val, "Repeated measures") && (ass_val <- if (isTruthy(input$assumptions)) input$assumptions else "") != "") {
          if (identical(ass_val, "Yes")) { test_name <- "Repeated Measures ANOVA"; desc <- "A repeated measures ANOVA is a statistical method used to compare the means of three or more groups when the same subjects are measured multiple times under different conditions or over several time points. For example, it can evaluate how a group of participants' blood pressure changes immediately after exercise, 30 minutes later, and one hour later."; use <- "Use for repeated measures designs with assumptions met."; assump <- "Normality, sphericity (homogeneity of variances of differences)."; next_steps <- "Perform Mauchly's test for sphericity. If violated, apply the Greenhouse-Geisser or Huynh-Feldt corrections to your degrees of freedom."; dive_topic <- "Sphericity" }
          else { test_name <- "Linear Mixed Model"; desc <- "A linear mixed model (LMM) is an advanced statistical method used to analyze data where data points are not independent, such as repeated measurements on the same subjects or data nested within groups. It achieves this by incorporating both fixed effects, which estimate the overall impact of your main variables of interest, and random effects, which account for variations across individual subjects or clusters."; use <- "Use for repeated measures with violated assumptions or unbalanced data."; assump <- "More flexible than repeated measures ANOVA."; next_steps <- "Specify the random intercepts and/or slopes for subjects. Choose an appropriate covariance structure (e.g., AR1) to model the correlation over time." }
        } else if (identical(str_val, "Nested design") && (ass_val <- if (isTruthy(input$assumptions)) input$assumptions else "") != "") {
          if (identical(ass_val, "Yes")) { test_name <- "Nested ANOVA"; desc <- "A nested ANOVA is a statistical method used when the levels of one factor are completely contained, or nested, within the levels of another factor rather than being crossed across them. For example, it can evaluate student performance by nesting individual classrooms within specific schools, ensuring the analysis accounts for the fact that Classroom A in School 1 is entirely distinct from Classroom A in School 2."; use <- "Use for nested designs with assumptions met."; assump <- "Normality, homogeneity of variance."; next_steps <- "Define the nesting structure clearly in your model formula. Ensure that the F-test for the higher-level factor uses the correct error term from the nested factor."; dive_topic <- "Homoscedasticity" }
          else { test_name <- "Mixed model"; desc <- "A mixed model is a flexible statistical framework used to analyze data where data points are clustered, hierarchical, or measured repeatedly over time, making them non-independent. It accounts for these complex structures by simultaneously estimating fixed effects for the overall population trends and random effects to capture the natural variation between individual subjects or groups."; use <- "Use for nested designs when assumptions are violated."; assump <- "More flexible than nested ANOVA."; next_steps <- "Treat the nested factors as random effects. Evaluate the variance components to understand how much variation exists at each level of the hierarchy." }
        }
      } else if (identical(res_type, "Count") && (ass_val <- if (isTruthy(input$assumptions)) input$assumptions else "") != "") {
        if (identical(ass_val, "No")) { test_name <- "Poisson GLM"; desc <- "A Poisson Generalized Linear Model (GLM) is a statistical method used to model and predict dependent variables that represent count data, such as the number of events occurring within a fixed timeframe or space. It uses a log link function to ensure predicted values stay strictly positive, making it ideal for data where the variance naturally increases along with the mean."; use <- "Use for count data when variance equals mean."; assump <- "Poisson distribution, no overdispersion."; next_steps <- "Check the residual deviance against the degrees of freedom. If the ratio is much greater than 1, consider switching to a Negative Binomial model."; dive_topic <- "Overdispersion & Dispersion" }
        else { test_name <- "Negative Binomial GLM"; desc <- "A Negative Binomial Generalized Linear Model (GLM) is a statistical method used to model count data when the variance of the data is significantly greater than the mean, a condition known as overdispersion. It extends the Poisson model by adding an extra parameter to flexibly account for this excess variation, ensuring more accurate standard errors and predictions for highly variable counts."; use <- "Use for count data when variance exceeds mean (overdispersion)."; assump <- "Negative binomial distribution."; next_steps <- "Fit the model and evaluate the dispersion parameter. Compare the model fit to a standard Poisson GLM using a Likelihood Ratio Test."; dive_topic <- "Overdispersion & Dispersion" }
      } else if (identical(res_type, "Binary") && (ind_val <- if (isTruthy(input$independence)) input$independence else "") != "") {
        if (identical(ind_val, "Yes")) { test_name <- "Logistic regression"; desc <- "Logistic regression is a statistical method used to model the probability of a binary outcome, where the dependent variable has only two possible results like yes/no, pass/fail, or true/false. It uses a logistic function to map any real-valued input into a probability between 0 and 1, allowing researchers to evaluate how various independent variables influence the likelihood of that specific outcome occurring."; use <- "Use for binary response variables with independent observations."; assump <- "Independence of observations, binary outcome."; next_steps <- "Interpret the coefficients as Odds Ratios. Evaluate model accuracy using a confusion matrix and the area under the ROC curve (AUC)."; dive_topic <- "Odds Ratios" }
        else { test_name <- "Generalized Linear Mixed Model (GLMM)"; desc <- "A GLMM is a statistical framework that extends linear mixed models to analyze non-normal data, such as counts or binary outcomes, where data points are nested, clustered, or measured repeatedly. It accomplishes this by combining a link function to handle the non-linear relationships of the data with both fixed effects for overall population trends and random effects to account for individual or group-level variations."; use <- "Use for binary response variables with repeated measures or clustering."; assump <- "Binary outcome, accounts for dependence structure."; next_steps <- "Include the grouping factor as a random effect. Check for model convergence and interpret the fixed effects while accounting for the random variation." }
      } else if (identical(res_type, "Proportion") && (prp_val <- if (isTruthy(input$proportion_type)) input$proportion_type else "") != "") {
        if (identical(prp_val, "Values bounded between 0 and 1")) { test_name <- "Beta regression"; desc <- "Beta Regression is a statistical method used to model a continuous dependent variable that is strictly bounded between 0 and 1, such as proportions, percentages, or rates. It assumes the data follows a beta distribution, allowing it to flexibly capture the highly skewed or asymmetric shapes common to rate data without predicting impossible values outside the 0 to 1 range."; use <- "Use for proportion data that are continuous and bounded."; assump <- "Beta distribution."; next_steps <- "Ensure no values are exactly 0 or 1. Check for precision in the estimates and evaluate the pseudo-R-squared value for model fit." }
        else { test_name <- "Binomial GLM"; desc <- "A GLM model is a statistical method used to model data where the dependent variable represents a series of successes and failures out of a fixed number of independent trials. It utilizes the link function, or logit link, to model the probability of success based on one or more independent variables, ensuring predictions stay strictly bounded between 0 and 1."; use <- "Use for binomial outcomes (successes/failures)."; assump <- "Binomial distribution."; next_steps <- "Format your response as a matrix of successes and failures. Check for overdispersion and consider a quasi-binomial model if necessary."; dive_topic <- "Overdispersion & Dispersion" }
      } else if (identical(res_type, "Ordinal") && (ind_val <- if (isTruthy(input$independence)) input$independence else "") != "") {
        if (identical(ind_val, "Yes")) { test_name <- "Ordinal logistic regression"; desc <- "Ordinal logistical regression is a statistical method used to model a dependent variable that has an inherant, ordered ranking, such as survey responses ranging from 'strongly disagree' to 'strongly agree.' It operates on the assumption of proportional odds, meaning the relationship between the independent variables and the likelihood of moving to a higher category remains constant across all thresholds of the ordering."; use <- "Use for ordinal response variables with independent observations."; assump <- "Independence of observations, ordinal outcome."; next_steps <- "Test the proportional odds assumption (Brant test). If it fails, consider using a partial proportional odds model or a different link function."; dive_topic <- "Proportional Odds" }
        else { test_name <- "Ordinal mixed model"; desc <- "The ordinal mixed model, or cumulative link mixed-model, is a statistical framework used to model a dependent variable with an inherent, ordered ranking when the data points are nested, clustered, or measured repeatedly. It accounts for these complex structures by simultaneously estimating fixed effects for the overall population trends and random effects to capture variation across individual subjects or groups."; use <- "Use for ordinal response variables with repeated measures or clustering."; assump <- "Ordinal outcome, accounts for dependence structure."; next_steps <- "Account for the repeated measures by adding a random effect for subjects. Evaluate the cumulative probabilities for each level of the ordinal response." }
      }
      #explore relationships bw variables
    } else if (identical(goal_val, "Relationship between variables")) {
      if (identical(res_type, "Continuous vs Continuous") && (ass_val <- if (isTruthy(input$assumptions)) input$assumptions else "") != "") {
        if (identical(ass_val, "Yes")) { test_name <- "Pearson correlation / Linear regression"; desc <- "Pearson correlation is a statistical measure that quantifies the strength and direction of a linear relationship between two continuous variables. Its value is strictly bounded between -1 and 1, where a score of zero indicates no linear association at all. Squaring the pearson correlation coefficient gives you the coefficient of determination in a simple linear regression model."; use <- "Use for normally distributed continuous variables with linear relationships."; assump <- "Normality, linearity, homoscedasticity."; next_steps <- "Calculate the correlation coefficient (r). For regression, check the residuals for normality and homoscedasticity using diagnostic plots."; dive_topic <- "Homoscedasticity" }
        else { test_name <- "Spearman correlation"; desc <- "Spearman correlation is a non-parametric measure that evaluates the strength and direction of a monotonic relationship between two variables by using their ranked values rather than their raw data. Because it focuses on ranks, it can handle non-linear relationships and is highly resilient to the influence of extreme outliers."; use <- "Use when normality assumption is violated or data are ordinal."; assump <- "Monotonic relationship, independence of observations."; next_steps <- "Rank the variables and calculate the rho (Žü) coefficient. Interpret the result as the strength of the monotonic (rather than linear) association." }
      } else if (identical(res_type, "Multivariate community/ecological data") && (mul_val <- if (isTruthy(input$multivariate_goal)) input$multivariate_goal else "") != "") {
        if (identical(mul_val, "Ordination")) { test_name <- "PCA / NMDS"; desc <- "While both methods reduce high-dimensional data into a visual map, PCA preserves the maximum variation using straight-line Euclidean distances, making it ideal for linear, continuous data. NMDS relaxes these strict geometric assumptions by using rank-orders of any distance metric you choose, making it far better suited for complex, non-linear biological or ecological community data."; use <- "Use to visualize and explore patterns in high-dimensional data."; assump <- "Depends on specific method; PCA assumes linearity."; next_steps <- "Generate an ordination plot. For NMDS, ensure the stress value is low (< 0.2). For PCA, check the proportion of variance explained by the first few axes."; dive_topic <- "Ordination Plot" }
        else { test_name <- "PERMANOVA"; desc <- "PERMANOVA is a non-parametric statistical test used to compare the geometric spaces of groups using any distance metric to see if their centoids are significantly different. Instead of relying on strict normal distribution assumptions, it uses random shuffling permutations of the actual data to calculate p-values, making it highly robust for complex ecological, biological, or high-dimensional datasets."; use <- "Use to compare community structure across groups."; assump <- "Independence of observations."; next_steps <- "Define your distance matrix (e.g., Bray-Curtis) and perform the permutation test. Check for multivariate homogeneity of dispersions (PERMDISP) to ensure group variances are similar." }
      } else if (identical(res_type, "Binary response") && (ind_val <- if (isTruthy(input$independence_rel)) input$independence_rel else "") != "") {
        if (identical(ind_val, "Yes")) { test_name <- "Logistic regression"; desc <- "Logistic Regression is a generalized linear model used to predict the probability of a binary outcome based on one or more predictor variables. It applies a logit link function to compress the linear regression equation's output into a strict range between 0 and 1, ensuring final predictions represent valid probabilities."; use <- "Use for binary response variables with independent observations."; assump <- "Independence of observations, binary outcome."; next_steps <- "Assess the significance of predictor variables. Use likelihood ratio tests to compare nested models and check for multicollinearity."; dive_topic <- "Odds Ratios" }
        else { test_name <- "GLMM"; desc <- "A GLMM extends standard generalized linear models by incorporating random effects alongside fixed effects to handle nested, clustered, or repeated measures data. This framework allows for the accurate analysis of non-normal outcomes, such as counts or binary responses, while properly controlling for correlation within groups."; use <- "Use for binary response variables with repeated measures or clustering."; assump <- "Binary outcome, accounts for dependence structure."; next_steps <- "Identify the correct random effect structure. Validate the model using deviance residuals and ensure the model has successfully converged." }
      } else if (identical(res_type, "Count response") && (ass_val <- if (isTruthy(input$assumptions)) input$assumptions else "") != "") {
        if (identical(ass_val, "No")) { test_name <- "Poisson regression"; desc <- "Poisson regression is a generalized linear model used to model dependent variables that consist of count data or rates representing occurences over a fixed period or area. It uses a log link function to ensure predicted values are strictly positive and assumes that the conditional variance of the outcome is exactly equal to the conditional mean."; use <- "Use for count data when variance equals mean."; assump <- "Poisson distribution, no overdispersion."; next_steps <- "Examine the relationship between the mean and variance. If overdispersion is detected, re-evaluate the model using a Negative Binomial distribution."; dive_topic <- "Overdispersion & Dispersion" }
        else { test_name <- "Negative Binomial regression"; desc <- "Negative binomial regression is a generalized linear model used to analyze count data that exhibits overdispersion, meaning the variance of the outcome is significantly greater than its mean. It addresses this issue by introducing an extra dispersion parameter that lets the variance vary flexibly, making it a highly reliable alternative when standard Poisson regression assumptions fail."; use <- "Use for count data when variance exceeds mean."; assump <- "Negative binomial distribution."; next_steps <- "Estimate the dispersion parameter. Use the model to predict counts and evaluate the fit using residual diagnostic plots."; dive_topic <- "Overdispersion & Dispersion" }
      } else if (identical(res_type, "Ordinal response") && (ind_val <- if (isTruthy(input$independence_rel)) input$independence_rel else "") != "") {
        if (identical(ind_val, "Yes")) { test_name <- "Ordinal logistic regression"; desc <- "Ordinal logistic regression is a statistical method used to model an ordered categorical dpendent variable, such as survey responses ranging from 'strongly disagree' to 'strongly agree'. It assumes proportional odds, meaning that the relationship between each predictor variable and the likelihood of moving to a higher category remains constant across all category thresholds."; use <- "Use for ordinal response variables with independent observations."; assump <- "Independence of observations, ordinal outcome."; next_steps <- "Interpret the coefficients as the change in log-odds of being in a higher category. Check the model fit using the deviance or AIC."; dive_topic <- "Proportional Odds" }
        else { test_name <- "Ordinal mixed model"; desc <- "An ordinal mixed model, or cululative linked model, analyzes an ordered categorical outcome while accounting for nested, clustered, or repeatedly measured data. It achieves this by combining the proportional odds assumption for the ranked categories with random effects that capture variation across individual subjects or groups."; use <- "Use for ordinal response variables with repeated measures or clustering."; assump <- "Ordinal outcome, accounts for dependence structure."; next_steps <- "Account for the hierarchical nature of the data by including random effects. Check for the consistency of the proportional odds assumption across different groups."; dive_topic <- "Proportional Odds" }
      }
      #predict or classify an outcome
    } else if (identical(goal_val, "Prediction / Classification")) {
      if (identical(res_type, "Continuous") && (lin_val <- if (isTruthy(input$linearity)) input$linearity else "") != "") {
        if (identical(lin_val, "Yes")) { test_name <- "Multiple linear regression"; desc <- "Multiple linear regression is a statistical method used to model the linear relationship between a single continuous dependent variable and two or more independent predictors. By calculating a unique slope coefficient for each predictor, it allows you to estimate the specific impact of an independent variable while holding all other variables constant."; use <- "Use for linear relationships between predictors and continuous outcome."; assump <- "Linearity, normality of residuals, homoscedasticity."; next_steps <- "Evaluate the R-squared value to determine the proportion of variance explained. Check for multicollinearity using the Variance Inflation Factor (VIF)."; dive_topic <- "Homoscedasticity" }
        else { test_name <- "GAM or nonlinear regression"; desc <- "Generalized Additive Models allow data trends to dictate the shape of the relationship using automatic smoothing splines, eliminating the need to guess the correct curve beforehand. In contrast, standard non-linear regression requires you to explicitly specify an exact, rigid mathematical fomula such as exponential or growth curve equations to fit the data."; use <- "Use when relationships are non-linear."; assump <- "Flexible."; next_steps <- "For GAMs, check the smoothing parameters (basis functions). For nonlinear regression, provide initial parameter estimates and evaluate the fit of the specified curve." }
      } else if (identical(res_type, "Binary") && (str_val <- if (isTruthy(input$structure_pred)) input$structure_pred else "") != "") {
        if (identical(str_val, "No")) { test_name <- "Logistic regression"; desc <- "Logistic regression is a generalized linear model used to predict the probability of a binary outcome based on one or more predictor variables. It applies a logit link function to compress the linear regression equation's output into a strict range between 0 and 1, ensuring final predictions represent valid probabilities."; use <- "Use for binary classification without repeated measures."; assump <- "Independence of observations, binary outcome."; next_steps <- "Use cross-validation to assess the model's predictive performance. Generate a confusion matrix to evaluate classification accuracy, sensitivity, and specificity."; dive_topic <- "Hold-out Data" }
        else { test_name <- "GLMM"; desc <- "GLMM combines the flexibility of generalized linear models to handle non-normal outcomes such as counts or binary data, with the power of mixed models to manage random effects. This approach allows you to accurately analyze clustered, nested, or repeated measures datasets while properly accounting for the correlation within those distinct groups."; use <- "Use for binary classification with repeated measures or clustering."; assump <- "Binary outcome, accounts for dependence structure."; next_steps <- "Validate the random effect structure. Use the model to predict the probability of the outcome while controlling for the group-level variability." }
      } else if (identical(res_type, "Count") && (ass_val <- if (isTruthy(input$assumptions)) input$assumptions else "") != "") {
        if (identical(ass_val, "No")) { test_name <- "Poisson regression"; desc <- "Poisson regression is a generalized linear model specifically designed for analyzing dependent variables that consist of count data or event rates. It uses a log link function to ensure all predicted counts are strictly positive and relies on the fundamental assumption that the conditional variance of the outcome is exactly equal to the conditional mean."; use <- "Use for count predictions when variance equals mean."; assump <- "Poisson distribution."; next_steps <- "Inspect the predicted counts against the observed data. Check for overdispersion and adjust the model if the mean-variance assumption is violated."; dive_topic <- "Overdispersion & Dispersion" }
        else { test_name <- "Negative Binomial regression"; desc <- "Negative binomial regression is a generalized linear model used to model count data when the variance is significantly larger than the mean, known as overdispersion. By adding a specific dispersion parameter to the model framework, it relaxes the rigid 'variance equals mean' assumption of standard Poisson regression to provide accurate standard errors and prevent overconfident conclusions."; use <- "Use for count predictions when variance exceeds mean."; assump <- "Negative binomial distribution."; next_steps <- "Evaluate the dispersion parameter. Use cross-validation or hold-out data to assess the accuracy of the count predictions."; dive_topic <- "Overdispersion & Dispersion" }
      } else if (identical(res_type, "Time-to-event / mortality / failure") && (cen_val <- if (isTruthy(input$censoring)) input$censoring else "") != "") {
        if (identical(cen_val, "Yes")) { test_name <- "Survival analysis (Cox model)"; desc <- "The Cox Proportional Hazards model is a semi-parametric survival analysis method used to evaluate how specific predictor variables influence the time until an event occurs, effortlessly handling right-censored data where the event is never observed. It operates on the core assumption of propoprtional hazards, meaning the relative risk associated with any predictor remains constant over time without the need to specify the baseline risk curve."; use <- "Use when some observations are censored (incomplete follow-up)."; assump <- "Proportional hazards."; next_steps <- "Verify the proportional hazards assumption using Schoenfeld residuals. Generate survival curves (Kaplan-Meier) to visualize the impact of key predictors."; dive_topic <- "Proportional Hazards" }
        else { test_name <- "Parametric survival model"; desc <- "A parametric survival model estimates the time until an event occurs by assuming the underlying baseline risk follows a specific, known mathematical distribution (such as Weibull, exponential, or log-normal). Because it fully specifies this distribution, it allows you to make precise, out-of-sample predictions about survival times, though its accuracy depends entirely on choosing the correct distribution of the data."; use <- "Use when all observations are complete (no censoring)."; assump <- "Specific parametric distribution."; next_steps <- "Test multiple distributions (e.g., Weibull vs. Exponential) and select the best fit based on AIC. Use the model to predict survival times for new observations."; dive_topic <- "Weibull & Exponential" }
      } else if (identical(res_type, "High-dimensional multivariate data") && (hgh_val <- if (isTruthy(input$high_dim_goal)) input$high_dim_goal else "") != "") {
        if (identical(hgh_val, "Dimension reduction")) { test_name <- "PCA"; desc <- "Principal Component Analysis is an unsupervised dimensionality-reduction technique used to transform a large set of correlated continuous variables into a smaller, uncorrelated set of linear combinations called principal components. It maximizes variance in fewer dimenstions by rotating the data's axes along the directions of greatest variability, allowing you to simplify complex datasets while retaining as much original informationa as possible."; use <- "Use to visualize and simplify high-dimensional datasets."; assump <- "Linearity."; next_steps <- "Identify the principal components that explain the most variance. Use these components as input for further analyses like clustering or regression."; dive_topic <- "Ordination Plot" }
        else { test_name <- "Discriminant analysis / Random Forest"; desc <- "Discriminant analysis is a parametric classification technique that uses linear or quadratic combinations of continuous predictors to maximize separation between known groups under strict assumptions of multivariate normality. In contrast, Random Forest is a non-parametric machine learning algorithm that builds an ensemble of uncorrelated decision trees to handle complex interactions, non-linear patterns, and high-dimenstional data wihtout requiring any distributional assumptions."; use <- "Use for classification with many predictors."; assump <- "Depends on method."; next_steps <- "For Discriminant Analysis, check for multivariate normality. For Random Forest, evaluate variable importance and use a test set to calculate classification accuracy."; dive_topic <- "Multivariate Normality" }
      }
    }
    list(name = test_name, desc = desc, use = use, assump = assump, next_steps = next_steps, dive_topic = dive_topic)
  })
  #output
  output$step_progress <- renderUI({
    res <- get_rec()
    percent <- if (!is.null(res$name)) 100 else {
      steps <- 1
      if (isTruthy(input$goal)) steps <- 2
      if (isTruthy(input$response_type)) steps <- 3
      s3_done <- any(sapply(c("structure", "independence", "multivariate_goal", "independence_rel", "linearity", "structure_pred", "high_dim_goal", "proportion_type", "censoring"), function(x) isTruthy(input[[x]])))
      if (s3_done) steps <- 4
      if (isTruthy(input$num_groups)) steps <- 5
      if (isTruthy(input$assumptions)) steps <- 6
      min(round((steps-1)/5 * 100), 80)
    }
    progressBar(id = "pbar", value = percent, status = if(percent==100) "success" else "primary", display_pct = TRUE, title = "Selection Progress")
  })
  
  output$response_ui <- renderUI({ req(input$goal); selectInput("response_type", "2. What is the type of the response variable?", choices = switch(input$goal, "Compare groups" = c("Select one" = "", "Continuous", "Count", "Binary", "Proportion", "Ordinal"), "Relationship between variables" = c("Select one" = "", "Continuous vs Continuous", "Multivariate community/ecological data", "Binary response", "Count response", "Ordinal response"), "Prediction / Classification" = c("Select one" = "", "Continuous", "Binary", "Count", "Time-to-event / mortality / failure", "High-dimensional multivariate data"))) })
  output$structure_ui <- renderUI({ req(input$response_type); if (input$goal == "Compare groups" && input$response_type == "Continuous") selectInput("structure", "3. What is the experimental structure?", choices = c("Select one" = "", "Completely Randomized Design (CRD)", "RCBD", "Split-plot", "Repeated measures", "Nested design")) else if (input$goal == "Compare groups" && input$response_type %in% c("Binary", "Ordinal")) selectInput("independence", "3. Are the observations independent?", choices = c("Select one" = "", "Yes", "No")) else if (input$goal == "Relationship between variables" && input$response_type == "Multivariate community/ecological data") selectInput("multivariate_goal", "3. What is the goal of the multivariate analysis?", choices = c("Select one" = "", "Ordination", "Group comparison")) else if (input$goal == "Relationship between variables" && input$response_type %in% c("Binary response", "Ordinal response")) selectInput("independence_rel", "3. Are the observations independent?", choices = c("Select one" = "", "Yes", "No")) else if (input$goal == "Prediction / Classification" && input$response_type == "Continuous") selectInput("linearity", "3. Is there a linear relationship?", choices = c("Select one" = "", "Yes", "No")) else if (input$goal == "Prediction / Classification" && input$response_type == "Binary") selectInput("structure_pred", "3. Is there a repeated or nested structure?", choices = c("Select one" = "", "Yes", "No")) else if (input$goal == "Prediction / Classification" && input$response_type == "High-dimensional multivariate data") selectInput("high_dim_goal", "3. What is the goal?", choices = c("Select one" = "", "Dimension reduction", "Classification")) else if (input$response_type == "Proportion") selectInput("proportion_type", "3. How are the values represented?", choices = c("Select one" = "", "Values bounded between 0 and 1", "Binomial counts")) else if (input$response_type == "Time-to-event / mortality / failure") selectInput("censoring", "3. Are there censored observations?", choices = c("Select one" = "", "Yes", "No")) })
  output$details_ui <- renderUI({ if (isTruthy(input$structure) && input$structure == "Completely Randomized Design (CRD)") selectInput("num_groups", "4. How many groups are being compared?", choices = c("Select one" = "", "2 groups", ">2 groups")) })
  output$assumptions_ui <- renderUI({ show_assumptions <- isTruthy(input$num_groups) || (isTruthy(input$structure) && input$structure %in% c("RCBD", "Split-plot", "Nested design")) || (isTruthy(input$response_type) && input$response_type %in% c("Count", "Count response", "Continuous vs Continuous")); if (isTruthy(input$structure) && input$structure == "Repeated measures") return(selectInput("assumptions", "5. Are normality and covariance assumptions met?", choices = c("Select one" = "", "Yes", "No"))); if (show_assumptions) selectInput("assumptions", if (isTruthy(input$response_type) && input$response_type %in% c("Count", "Count response")) "4. Is overdispersion present?" else "5. Are the necessary assumptions met?", choices = c("Select one" = "", "Yes", "No")) })
  
  output$recommendation_ui <- renderUI({
    res <- get_rec()
    if (!is.null(res$name)) {
      div(class = "recommendation-box",
          h3("Recommended Analysis:", style = "color: var(--uf-blue); margin-top: 0;"),
          h2(style = "color: var(--uf-orange); font-weight: bold;", res$name), hr(),
          p(HTML(paste0("<strong>Description:</strong> ", res$desc))),
          p(HTML(paste0("<strong>When to use:</strong> ", res$use))),
          p(HTML(paste0("<strong>Assumptions:</strong> ", res$assump))),
          if (!is.null(res$dive_topic)) { actionLink("go_to_deepdive", paste0("Learn more about ", res$dive_topic, " in the Assumptions Explanation tab"), class="learn-more-link") },
          div(class = "next-steps", h4(icon("list-check"), "Next Steps for Data Analysis:"), p(res$next_steps))
      )
    } else { div(class = "well", p(icon("arrow-left"), " Please complete the selections in the sidebar to receive a detailed recommendation.")) }
  })
}
