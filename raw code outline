soring", "3. Are there censored observations?", choices = c("Select one" = "", "Yes", "No")) })
  output$details_ui <- renderUI({ if (isTruthy(input$structure) && input$structure == "Completely Randomized Design (CRD)") selectInput("num_groups", "4. How many groups are being compared?", choices = c("Select one" = "", "2 groups", ">2 groups")) })
  output$assumptions_ui <- renderUI({ show_assumptions <- isTruthy(input$num_groups) || (isTruthy(input$structure) && input$structure %in% c("RCBD", "Split-plot", "Nested design")) || (isTruthy(input$response_type) && input$response_type %in% c("Count", "Count response", "Continuous vs Continuous")); if (isTruthy(input$structure) && input$structure == "Repeated measures") return(selectInput("assumptions", "5. Are normality and covariance assumptions met?", choices = c("Select one" = "", "Yes", "No"))); if (show_assumptions) selectInput("assumptions", if (isTruthy(input$response_type) && input$response_type %in% c("Count", "Count response")) "4. Is overdispersion present?" else "5. Are the necessary assumptions met?", choices = c("Select one" = "", "Yes", "No")) })
  
  output$recommendation_ui <- renderUI({
    res <- get_rec()
    if (!is.null(res$name)) {
      div(class = "recommendation-box",
        h3("Recommended Analysis:", style = "color: var(--uf-blue); margin-top: 0;"),
        h2(style = "color: var(--uf-orange); font-weight: bold;", res$name), hr(),
        p(HTML(paste0("<strong>Description:</strong> ", res$desc))),
        p(HTML(paste0("<strong>When to use:</strong> ", res$use))),
        p(HTML(paste0("<strong>Assumptions:</strong> ", res$assump))),
        if (!is.null(res$dive_topic)) { actionLink("go_to_assumption", paste0("Learn more about ", res$dive_topic, " in the Assumption Check Guide tab"), class="learn-more-link") },
        div(class = "next-steps", h4(icon("list-check"), "Next Steps for Data Analysis:"), p(res$next_steps))
