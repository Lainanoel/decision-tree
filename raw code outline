        else { test_name <- "GAM or nonlinear regression"; desc <- "Generalized Additive Models allow data trends to dictate the shape of the relationship using automatic smoothing splines, eliminating the need to guess the correct curve beforehand. In contrast, standard non-linear regression requires you to explicitly specify an exact, rigid mathematical fomula such as exponential or growth curve equations to fit the data."; use <- "Use when relationships are non-linear."; assump <- "Flexible."; next_steps <- "For GAMs, check the smoothing parameters (basis functions). For nonlinear regression, provide initial parameter estimates and evaluate the fit of the specified curve." }
