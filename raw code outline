        else { test_name <- "Binomial GLM"; desc <- "A GLM model is a statistical method used to model data where the dependent variable represents a series of successes and failures out of a fixed number of independent trials. It utilizes the link function, or logit link, to model the probability of success based on one or more independent variables, ensuring predictions stay strictly bounded between 0 and 1."; use <- "Use for binomial outcomes (successes/failures)."; assump <- "Binomial distribution."; next_steps <- "Format your response as a matrix of successes and failures. Check for overdispersion and consider a quasi-binomial model if necessary."; dive_topic <- "Overdispersion" }
      } else if (identical(res_type, "Ordinal") && (ind_val <- if (isTruthy(input$independence)) input$independence else "") != "") {
        if (identical(ind_val, "Yes")) { test_name <- "Ordinal logistic regression"; desc <- "Ordinal logistical regression is a statistical method used to model a dependent variable that has an inherant, ordered ranking, such as survey responses ranging from 'strongly disagree' to 'strongly agree.' It operates on the assumption of proportional odds, meaning the relationship between the independent variables and the likelihood of moving to a higher category remains constant across all thresholds of the ordering."; use <- "Use for ordinal response variables with independent observations."; assump <- "Independence of observations, ordinal outcome."; next_steps <- "Test the proportional odds assumption (Brant test). If it fails, consider using a partial proportional odds model or a different link function."; dive_topic <- "Proportional Odds" }
