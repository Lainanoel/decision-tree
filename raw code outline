    } else if (identical(goal_val, "Relationship between variables")) {
      if (identical(res_type, "Continuous vs Continuous") && (ass_val <- if (isTruthy(input$assumptions)) input$assumptions else "") != "") {
        if (identical(ass_val, "Yes")) { test_name <- "Pearson correlation / Linear regression"; desc <- "Pearson correlation is a statistical measure that quantifies the strength and direction of a linear relationship between two continuous variables. Its value is strictly bounded between -1 and 1, where a score of zero indicates no linear association at all. Squaring the pearson correlation coefficient gives you the coefficient of determination in a simple linear regression model."; use <- "Use for normally distributed continuous variables with linear relationships."; assump <- "Normality, linearity, homoscedasticity."; next_steps <- "Calculate the correlation coefficient (r). For regression, check the residuals for normality and homoscedasticity using diagnostic plots."; dive_topic <- "Linearity" }
        else { test_name <- "Spearman correlation"; desc <- "Spearman correlation is a non-parametric measure that evaluates the strength and direction of a monotonic relationship between two variables by using their ranked values rather than their raw data. Because it focuses on ranks, it can handle non-linear relationships and is highly resilient to the influence of extreme outliers."; use <- "Use when normality assumption is violated or data are ordinal."; assump <- "Monotonic relationship, independence of observations."; next_steps <- "Rank the variables and calculate the rho (ρ) coefficient. Interpret the result as the strength of the monotonic (rather than linear) association." }
      } else if (identical(res_type, "Multivariate community/ecological data") && (mul_val <- if (isTruthy(input$multivariate_goal)) input$multivariate_goal else "") != "") {
        if (identical(mul_val, "Ordination")) { test_name <- "PCA / NMDS"; desc <- "While both methods reduce high-dimensional data into a visual map, PCA preserves the maximum variation using straight-line Euclidean distances, making it ideal for linear, continuous data. NMDS relaxes these strict geometric assumptions by using rank-orders of any distance metric you choose, making it far better suited for complex, non-linear biological or ecological community data."; use <- "Use to visualize and explore patterns in high-dimensional data."; assump <- "Depends on specific method; PCA assumes linearity."; next_steps <- "Generate an ordination plot. For NMDS, ensure the stress value is low (< 0.2). For PCA, check the proportion of variance explained by the first few axes."; dive_topic <- "Linearity" }
        else { test_name <- "PERMANOVA"; desc <- "PERMANOVA is a non-parametric statistical test used to compare the geometric spaces of groups using any distance metric to see if their centoids are significantly different. Instead of relying on strict normal distribution assumptions, it uses random shuffling permutations of the actual data to calculate p-values, making it highly robust for complex ecological, biological, or high-dimensional datasets."; use <- "Use to compare community structure across groups."; assump <- "Independence of observations."; next_steps <- "Define your distance matrix (e.g., Bray-Curtis) and perform the permutation test. Check for multivariate homogeneity of dispersions (PERMDISP) to ensure group variances are similar." }
      } else if (identical(res_type, "Binary response") && (ind_val <- if (isTruthy(input$independence_rel)) input$independence_rel else "") != "") {
