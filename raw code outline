      if (isTruthy(input$num_groups)) steps <- 5
      if (isTruthy(input$assumptions)) steps <- 6
      min(round((steps-1)/5 * 100), 80)
    }
    progressBar(id = "pbar", value = percent, status = if(percent==100) "success" else "primary", display_pct = TRUE, title = "Selection Progress")
  })

  output$response_ui <- renderUI({ req(input$goal); selectInput("response_type", "2. What is the type of the response variable?", choices = switch(input$goal, "Compare groups" = c("Select one" = "", "Continuous", "Count", "Binary", "Proportion", "Ordinal"), "Relationship between variables" = c("Select one" = "", "Continuous vs Continuous", "Multivariate community/ecological data", "Binary response", "Count response", "Ordinal response"), "Prediction / Classification" = c("Select one" = "", "Continuous", "Binary", "Count", "Time-to-event / mortality / failure", "High-dimensional multivariate data"))) })
