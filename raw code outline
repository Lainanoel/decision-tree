      } else if (identical(res_type, "Count") && (ass_val <- if (isTruthy(input$assumptions)) input$assumptions else "") != "") {
        if (identical(ass_val, "No")) { test_name <- "Poisson GLM"; desc <- "A Poisson Generalized Linear Model (GLM) is a statistical method used to model and predict dependent variables that represent count data, such as the number of events occurring within a fixed timeframe or space. It uses a log link function to ensure predicted values stay strictly positive, making it ideal for data where the variance naturally increases along with the mean."; use <- "Use for count data when variance equals mean."; assump <- "Poisson distribution, no overdispersion."; next_steps <- "Check the residual deviance against the degrees of freedom. If the ratio is much greater than 1, consider switching to a Negative Binomial model."; dive_topic <- "Overdispersion" }
        else { test_name <- "Negative Binomial GLM"; desc <- "A Negative Binomial Generalized Linear Model (GLM) is a statistical method used to model count data when the variance of the data is significantly greater than the mean, a condition known as overdispersion. It extends the Poisson model by adding an extra parameter to flexibly account for this excess variation, ensuring more accurate standard errors and predictions for highly variable counts."; use <- "Use for count data when variance exceeds mean (overdispersion)."; assump <- "Negative binomial distribution."; next_steps <- "Fit the model and evaluate the dispersion parameter. Compare the model fit to a standard Poisson GLM using a Likelihood Ratio Test."; dive_topic <- "Overdispersion" }
      } else if (identical(res_type, "Binary") && (ind_val <- if (isTruthy(input$independence)) input$independence else "") != "") {
        if (identical(ind_val, "Yes")) { test_name <- "Logistic regression"; desc <- "Logistic regression is a statistical method used to model the probability of a binary outcome, where the dependent variable has only two possible results like yes/no, pass/fail, or true/false. It uses a logistic function to map any real-valued input into a probability between 0 and 1, allowing researchers to evaluate how various independent variables influence the likelihood of that specific outcome occurring."; use <- "Use for binary response variables with independent observations."; assump <- "Independence of observations, binary outcome."; next_steps <- "Interpret the coefficients as Odds Ratios. Evaluate model accuracy using a confusion matrix and the area under the ROC curve (AUC)."; dive_topic <- "Independence of Observations" }
        else { test_name <- "Generalized Linear Mixed Model (GLMM)"; desc <- "A GLMM is a statistical framework that extends linear mixed models to analyze non-normal data, such as counts or binary outcomes, where data points are nested, clustered, or measured repeatedly. It accomplishes this by combining a link function to handle the non-linear relationships of the data with both fixed effects for overall population trends and random effects to account for individual or group-level variations."; use <- "Use for binary response variables with repeated measures or clustering."; assump <- "Binary outcome, accounts for dependence structure."; next_steps <- "Include the grouping factor as a random effect. Check for model convergence and interpret the fixed effects while accounting for the random variation." }
      } else if (identical(res_type, "Proportion") && (prp_val <- if (isTruthy(input$proportion_type)) input$proportion_type else "") != "") {
