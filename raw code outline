server <- function(input, output, session) {
  observeEvent(input$reset, { updateSelectInput(session, "goal", selected = "") })
  observeEvent(input$go_to_assumption, { updateNavbarPage(session, "nav", selected = "assumption_guide") })

  # Searchable Glossary Logic (Including technical definitions)
  glossary_data <- list(
    "Alternative Hypothesis" = "The statement that there is a specific effect, relationship, or difference between variables, which you accept if the null hypothesis is rejected.",
    "Analysis of Variance (ANOVA)" = "A statistical method used to test differences between two or more means by analyzing the variances of the groups.",
    "Autocorrelation" = "A characteristic of data in which values of a variable are correlated with past values of themselves over successive time intervals.",
    "Bias" = "The systematic tendency of an estimator to underestimate or overestimate a true population parameter.",
    "Binary" = "Data with only two outcomes (e.g., Dead/Alive, Yes/No).",
    "Censoring" = "A data condition where the value of an observation is only partially known, typically because it falls outside the range of measurement or occurs outside the study window.",
    "Central Limit Theorem (CLT)" = "A fundamental principle stating that as sample size grows large, the sampling distribution of the mean approaches a normal distribution, regardless of the population's original shape.",
    "Coefficient of Determination (R^2)" = "A statistical measure that represents the proportion of the variance for a dependent variable that's explained by an independent variable or variables in a regression model.",
    "Confidence Interval" = "A range of values derived from sample statistics that is likely to contain the true population parameter with a specified level of probability.",
    "Confounding Variable" = "An extraneous factor that correlates with both the dependent and independent variables, potentially masking or distorting the true relationship between them.",
    "Continuous" = "Data that can take any value in a range (e.g., height, yield).",
    "Degrees of Freedom" = "The number of independent values or quantities which can be assigned to a statistical distribution without violating any constraints.",
    "Dispersion" = "Refers to the spread of data. Overdispersion occurs when variance is higher than expected by the model.",
    "Dummy Variable" = "A numerical variable used in regression analysis to represent categorical data, taking a value of 0 or 1 to indicate the absence or presence of a specific attribute.",
    "Econometrics" = "The application of statistical and mathematical methods to economic data in order to test hypotheses, estimate parameters, and forecast future trends.",
    "Endogeneity" = "A situation in a regression model where an explanatory variable is correlated with the error term, often caused by omitted variables, measurement error, or simultaneity.",
    "Euclidean Distance" = "The straight-line distance between two coordinates in a multi-dimensional space, calculated as the square root of the sum of squared differences between those coordinates.",
    "Experimental Group" = "A group of subjects in a study or experiment that receives the specific treatment or intervention being tested.",
    "Exponential Distribution" = "A continuous probability distribution used to model the time or space between independent, consecutive events occurring at a constant average rate.",
    "Heteroskedasticity" = "A condition in regression analysis where the variance of the residuals (error terms) is unequal across all levels of the independent variables.",
    "Hold-out Data" = "Data set aside during model building to provide an unbiased evaluation of the final model's predictive accuracy.",
    "Homoscedasticity" = "Explaining constant variance in linear models.",
    "Independence" = "A condition between random variables where the occurrence or value of one yields no predictive information about the probability or value of the other.",
    "Linear Probability Model (LPM)" = "An OLS regression framework applied to a binary outcome variable, estimating the direct effect of independent variables on the probability of an event occurring.",
    "Log-Normal Distribution" = "A continuous probability distribution of a random variable whose logarithm is normally distributed. Often used for data that is skewed and cannot be negative.",
    "Logit Model" = "A non-linear regression model used to predict the probability of a binary dependent variable using a logistic function, ensuring predicted values fall strictly between 0 and 1.",
    "Mean" = "The mathematical average of a dataset, calculated by summing all observed values and dividing by the total number of observations.",
    "Median" = "The middle value in a list of numbers sorted from smallest to largest.",
    "Multivariate Analysis" = "A set of advanced statistical techniques used to simultaneously evaluate, manipulate, and analyze data involving more than one outcome or dependent variable.",
    "Multivariate Normality" = "Assumes all variables in a multivariate set are normally distributed in combination. Required for MANOVA and DA.",
    "Normal Distribution" = "A probability distribution that is symmetric about the mean, showing that data near the mean are more frequent in occurrence than data far from the mean.",
    "Null Hypothesis" = "The foundational baseline assumption in a hypothesis test stating that no significant difference, effect, or relationship exists between the studied variables.",
    "Odds Ratios" = "A measure of association between an exposure and an outcome.",
    "Omitted Variable Bias" = "A bias that occurs when a regression model leaves out a relevant variable that is correlated with both the dependent and independent variables.",
    "Ordinal" = "Categorical data with a clear order or ranking (e.g., survey responses: Low, Med, High).",
    "Ordination Plot" = "A visual representation (like PCA or NMDS) that maps high-dimensional data into 2D or 3D space.",
    "Outlier" = "An anomalous data point that deviates significantly from the central tendency of the remaining dataset.",
    "Overdispersion" = "Occurs when variance is higher than expected by the model.",
    "P-value" = "The exact probability of obtaining a test statistic at least as extreme as the one observed, calculated under the assumption that the null hypothesis is completely true.",
    "Parametric" = "Statistical tests that assume the data follows a specific distribution (usually normal) and has equal variances across groups.",
    "Post Hoc Test" = "A stepwise statistical adjustment conducted after an ANOVA to determine exactly which specific group pairs possess statistically significant differences.",
    "Probit Model" = "A non-linear regression model designed for binary dependent variables that uses the cumulative standard normal distribution function to map predictions between 0 and 1.",
    "Proportional Hazards" = "Assumes the ratio of the hazard rates for any two groups is constant over time. Crucial for Cox survival models.",
    "Proportional Odds" = "In ordinal regression, assumes the effect of each predictor is consistent across all levels of the ranked outcome.",
    "Regression Analysis" = "A set of statistical modeling processes used to estimate the strength, direction, and significance of relationships between a dependent variable and one or more independent factors.",
    "Residual" = "The difference between an observed value and the predicted value generated by a statistical model.",
    "Spectrophotometry" = "A quantitative methodology used to measure how much chemical substance absorbs light by measuring the intensity of light as a beam passes through a sample solution.",
    "Standard Deviation" = "A metric that quantifies the average amount of variation or spread of individual data points around their mathematical mean.",
    "Type I Error" = "The mistake of rejecting a null hypothesis when it is actually true (a false positive).",
    "Variance" = "The expectation of the squared deviation of a random variable from its mean, serving as a fundamental metric for how dispersed a distribution is.",
    "Weibull & Exponential" = "Parametric distributions used in survival analysis."
  )

  output$glossary_results <- renderUI({
    query <- tolower(input$glossary_search)
    terms <- names(glossary_data)
    if (query != "") terms <- terms[grepl(query, tolower(terms)) | grepl(query, tolower(unlist(glossary_data[terms])))]
    if (length(terms) == 0) return(p("No matching terms found.", style="padding: 10px;"))
    tagList(lapply(sort(terms), function(term) {
      div(style="padding: 10px; border-bottom: 1px solid #eee;",
        span(class="glossary-term", term), br(), p(glossary_data[[term]])
      )
    }))
  })

  # Data Analyzer Logic
  data_reactive <- reactive({ req(input$file1); read.csv(input$file1$datapath) })
  output$var_selection_ui <- renderUI({ df <- data_reactive(); tagList(selectInput("response_var", "Select Response Variable (Numeric)", choices = names(df)[sapply(df, is.numeric)]), selectInput("group_var", "Select Grouping Variable (Factor)", choices = names(df))) })
  output$analyzer_results_ui <- renderUI({ req(input$response_var, input$group_var); df <- data_reactive(); y <- df[[input$response_var]]; group <- df[[input$group_var]]; sw_test <- tryCatch(shapiro.test(y), error = function(e) NULL); bt_test <- tryCatch(bartlett.test(y ~ group), error = function(e) NULL); tagList(h4("Normality Check (Shapiro-Wilk)"), if (!is.null(sw_test)) { div(class = paste("analyzer-result", if(sw_test$p.value > 0.05) "pass" else "fail"), p(strong("Result: "), if(sw_test$p.value > 0.05) "Data appears Normal" else "Data is NOT Normal"), p("p-value: ", round(sw_test$p.value, 4))) } else { p("Error running normality test.") }, h4("Homogeneity Check (Bartlett's)"), if (!is.null(bt_test)) { div(class = paste("analyzer-result", if(bt_test$p.value > 0.05) "pass" else "fail"), p(strong("Result: "), if(bt_test$p.value > 0.05) "Variances are Equal" else "Variances are NOT Equal"), p("p-value: ", round(bt_test$p.value, 4))) } else { p("Error running homogeneity test.") }) })

  get_rec <- reactive({
    req(input$goal)
    goal_val <- input$goal
    res_type <- if (isTruthy(input$response_type)) input$response_type else ""
    test_name <- NULL; desc <- NULL; use <- NULL; assump <- NULL; next_steps <- NULL; dive_topic <- NULL

    if (identical(goal_val, "Compare groups")) {
      if (identical(res_type, "Continuous")) {
        str_val <- if (isTruthy(input$structure)) input$structure else ""
        if (identical(str_val, "Completely Randomized Design (CRD)")) {
          det_val <- if (isTruthy(input$num_groups)) input$num_groups else ""
          ass_val <- if (isTruthy(input$assumptions)) input$assumptions else ""
          if (identical(det_val, "2 groups") && ass_val != "") {
            if (identical(ass_val, "Yes")) { test_name <- "Independent t-test"; desc <- "Compares the means of two independent groups."; use <- "An independent $t$-test is a statistical method used to compare the means of two separate, unrelated groups to determine if there is a significant difference between them. For example, it can evaluate whether a treatment group performed better on a test than a control group that received no treatment."; assump <- "Normality, homogeneity of variance, independence of observations."; next_steps <- "Perform a Shapiro-Wilk test for normality and Levene's test for equality of variances. If significant, report the t-statistic, degrees of freedom, and p-value."; dive_topic <- "Homogeneity of Variance" }
            else { test_name <- "Mann–Whitney U test"; desc <- "The Mann-Whitney U test is a non-parametric statistical method used to compare the distributions of two independent groups when the data do not meet the normality assumptions required for a standard t-test. Instead of comparing averages, it ranks all the data points to determine if one group's values systematically tend to be larger or smaller than the other's."; use <- "Use when assumptions for the t-test are not met or data are ordinal."; assump <- "Independence of observations, ordinal or continuous data."; next_steps <- "Rank the data points across groups and perform the test. Report the U-statistic and p-value, and consider the median difference if distributions are similar." }
          } else if (identical(det_val, ">2 groups") && ass_val != "") {
            if (identical(ass_val, "Yes")) { test_name <- "One-way ANOVA"; desc <- "A one-way ANOVA (Analysis of Variance) test is a statistical method used to compare the means of three or more independent groups with continuous data to see if at least one group differs significantly from the others. For example, it can evaluate whether there is a difference in exam scores among students who used three distinct studying techniques."; use <- "A one-way ANOVA (Analysis of Variance) test is a statistical method used to compare the means of three or more independent groups with continuous data to see if at least one group differs significantly from the others."; assump <- "Normality, homogeneity of variance, independence of observations."; next_steps <- "Perform the ANOVA. If the result is significant (p < 0.05), follow up with a Tukey's HSD post-hoc test to identify which specific groups differ."; dive_topic <- "Homogeneity of Variance" }
            else { test_name <- "Kruskal–Wallis test"; desc <- "Non-parametric alternative to one-way ANOVA."; use <- "The Kruskal-Wallis test is a non-parametric statistical method used to compare the distributions of three or more independent groups when the data do not meet the normality assumptions required for a one-way ANOVA. Instead of comparing group means, it ranks all data points combined to determine if at least one group's scores systematically differ from the others."; assump <- "Independence of observations, ordinal or continuous data."; next_steps <- "Perform the test on the ranks of the data. If significant, use a post-hoc test like Dunn's test to perform pairwise comparisons between groups." }
          }
        } else if (identical(str_val, "RCBD") && (ass_val <- if (isTruthy(input$assumptions)) input$assumptions else "") != "") {
          if (identical(ass_val, "Yes")) { test_name <- "RCBD ANOVA"; desc <- "A Randomized Complete Block Design (RCBD) ANOVA is a statistical method used to compare the means of three or more groups while controlling for an extraneous variable, known as a block, that could skew the results. For example, it can evaluate the effectiveness of three different treatments across multiple field locations, using the locations as blocks to filter out variations in soil quality."; use <- "Use for blocked experimental designs where assumptions are met."; assump <- "Normality, homogeneity of variance."; next_steps <- "Include the 'Block' effect in your model. Check the significance of the treatment effect while accounting for block-to-block variation."; dive_topic <- "Homogeneity of Variance" }
          else { test_name <- "Friedman test"; desc <- "The Friedman test is a non-parametric statistical method used to detect differences in treatments across multiple test attempts or matched groups when the data do not meet the assumptions of normality. It essentially serves as the non-parametric alternative to a repeated measures ANOVA, ranking the data within each block or subject to see if there is a consistent, significant trend."; use <- "Use for blocked designs when assumptions are not met."; assump <- "Independence within blocks."; next_steps <- "Organize data into a matrix by blocks and treatments. Perform the test and use Nemenyi post-hoc tests if the overall result is significant." }
        } else if (identical(str_val, "Split-plot") && (ass_val <- if (isTruthy(input$assumptions)) input$assumptions else "") != "") {
          if (identical(ass_val, "Yes")) { test_name <- "Split-plot ANOVA"; desc <- "A split-plot ANOVA is a statistical method used when experimental units are nested within two different levels of treatment, separating them into large whole plots for one factor and smaller subplots for another. For example, it can evaluate how different irrigation types (whole-plot factor) and fertilizer brands (subplot factor) affect crop yield within the same field."; use <- "Use for split-plot designs with assumptions met."; assump <- "Normality, homogeneity of variance."; next_steps <- "Ensure you use the correct error terms (whole-plot error vs subplot error) to calculate the F-statistics for each factor level."; dive_topic <- "Homogeneity of Variance" }
          else { test_name <- "Mixed model with transformed/nonparametric approach"; desc <- "A mixed model with a transformed nonparametric approach applies a mathematical transformation—such as ranking or aligned ranks—to the data before running a linear mixed-effects model to handle complex, non-normal datasets with both fixed and random effects. This hybrid method allows researchers to robustly analyze longitudinal or clustered data with repeated measures without violating standard parametric assumptions like normality and homoscedasticity."; use <- "Use when assumptions are violated; may require data transformation."; assump <- "More flexible than ANOVA."; next_steps <- "Consider using a rank-transformation or an Aligned Rank Transform (ART) before fitting your mixed-effects model." }
        } else if (identical(str_val, "Repeated measures") && (ass_val <- if (isTruthy(input$assumptions)) input$assumptions else "") != "") {
          if (identical(ass_val, "Yes")) { test_name <- "Repeated Measures ANOVA"; desc <- "A repeated measures ANOVA is a statistical method used to compare the means of three or more groups when the same subjects are measured multiple times under different conditions or over several time points. For example, it can evaluate how a group of participants' blood pressure changes immediately after exercise, 30 minutes later, and one hour later."; use <- "Use for repeated measures designs with assumptions met."; assump <- "Normality, sphericity (homogeneity of variances of differences)."; next_steps <- "Perform Mauchly's test for sphericity. If violated, apply the Greenhouse-Geisser or Huynh-Feldt corrections to your degrees of freedom."; dive_topic <- "Sphericity" }
          else { test_name <- "Linear Mixed Model"; desc <- "A linear mixed model (LMM) is an advanced statistical method used to analyze data where data points are not independent, such as repeated measurements on the same subjects or data nested within groups. It achieves this by incorporating both fixed effects, which estimate the overall impact of your main variables of interest, and random effects, which account for variations across individual subjects or clusters."; use <- "Use for repeated measures with violated assumptions or unbalanced data."; assump <- "More flexible than repeated measures ANOVA."; next_steps <- "Specify the random intercepts and/or slopes for subjects. Choose an appropriate covariance structure (e.g., AR1) to model the correlation over time." }
        } else if (identical(str_val, "Nested design") && (ass_val <- if (isTruthy(input$assumptions)) input$assumptions else "") != "") {
          if (identical(ass_val, "Yes")) { test_name <- "Nested ANOVA"; desc <- "A nested ANOVA is a statistical method used when the levels of one factor are completely contained, or nested, within the levels of another factor rather than being crossed across them. For example, it can evaluate student performance by nesting individual classrooms within specific schools, ensuring the analysis accounts for the fact that Classroom A in School 1 is entirely distinct from Classroom A in School 2."; use <- "Use for nested designs with assumptions met."; assump <- "Normality, homogeneity of variance."; next_steps <- "Define the nesting structure clearly in your model formula. Ensure that the F-test for the higher-level factor uses the correct error term from the nested factor."; dive_topic <- "Homogeneity of Variance" }
          else { test_name <- "Mixed model"; desc <- "A mixed model is a flexible statistical framework used to analyze data where data points are clustered, hierarchical, or measured repeatedly over time, making them non-independent. It accounts for these complex structures by simultaneously estimating fixed effects for the overall population trends and random effects to capture the natural variation between individual subjects or groups."; use <- "Use for nested designs when assumptions are violated."; assump <- "More flexible than nested ANOVA."; next_steps <- "Treat the nested factors as random effects. Evaluate the variance components to understand how much variation exists at each level of the hierarchy." }
