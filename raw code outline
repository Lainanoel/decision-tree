        else { test_name <- "Discriminant analysis / Random Forest"; desc <- "Discriminant analysis is a parametric classification technique that uses linear or quadratic combinations of continuous predictors to maximize separation between known groups under strict assumptions of multivariate normality. In contrast, Random Forest is a non-parametric machine learning algorithm that builds an ensemble of uncorrelated decision trees to handle complex interactions, non-linear patterns, and high-dimenstional data wihtout requiring any distributional assumptions."; use <- "Use for classification with many predictors."; assump <- "Depends on method."; next_steps <- "For Discriminant Analysis, check for multivariate normality. For Random Forest, evaluate variable importance and use a test set to calculate classification accuracy."; dive_topic <- "Multivariate Normality" }
