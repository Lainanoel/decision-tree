        if (identical(str_val, "No")) { test_name <- "Logistic regression"; desc <- "Logistic regression is a generalized linear model used to predict the probability of a binary outcome based on one or more predictor variables. It applies a logit link function to compress the linear regression equation's output into a strict range between 0 and 1, ensuring final predictions represent valid probabilities."; use <- "Use for binary classification without repeated measures."; assump <- "Independence of observations, binary outcome."; next_steps <- "Use cross-validation to assess the model's predictive performance. Generate a confusion matrix to evaluate classification accuracy, sensitivity, and specificity."; dive_topic <- "Independence of Observations" }
        else { test_name <- "GLMM"; desc <- "GLMM combines the flexibility of generalized linear models to handle non-normal outcomes such as counts or binary data, with the power of mixed models to manage random effects. This approach allows you to accurately analyze clustered, nested, or repeated measures datasets while properly accounting for the correlation within those distinct groups."; use <- "Use for binary classification with repeated measures or clustering."; assump <- "Binary outcome, accounts for dependence structure."; next_steps <- "Validate the random effect structure. Use the model to predict the probability of the outcome while controlling for the group-level variability." }
      } else if (identical(res_type, "Count") && (ass_val <- if (isTruthy(input$assumptions)) input$assumptions else "") != "") {
