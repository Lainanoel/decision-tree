        else { test_name <- "GLMM"; desc <- "A GLMM extends standard generalized linear models by incorporating random effects alongside fixed effects to handle nested, clustered, or repeated measures data. This framework allows for the accurate analysis of non-normal outcomes, such as counts or binary responses, while properly controlling for correlation within groups."; use <- "Use for binary response variables with repeated measures or clustering."; assump <- "Binary outcome, accounts for dependence structure."; next_steps <- "Identify the correct random effect structure. Validate the model using deviance residuals and ensure the model has successfully converged." }
