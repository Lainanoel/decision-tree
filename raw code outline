        else { test_name <- "Parametric survival model"; desc <- "A parametric survival model estimates the time until an event occurs by assuming the underlying baseline risk follows a specific, known mathematical distribution (such as Weibull, exponential, or log-normal). Because it fully specifies this distribution, it allows you to make precise, out-of-sample predictions about survival times, though its accuracy depends entirely on choosing the correct distribution of the data."; use <- "Use when all observations are complete (no censoring)."; assump <- "Specific parametric distribution."; next_steps <- "Test multiple distributions (e.g., Weibull vs. Exponential) and select the best fit based on AIC. Use the model to predict survival times for new observations." }
