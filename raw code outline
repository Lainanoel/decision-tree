      if (isTruthy(input$response_type)) steps <- 3
      s3_done <- any(sapply(c("structure", "independence", "multivariate_goal", "independence_rel", "linearity", "structure_pred", "high_dim_goal", "proportion_type", "censoring"), function(x) isTruthy(input[[x]])))
